+    monitorFilter() {
+      this.currentPage = 1;
+      this.loadHosts(true);
+    },
+    siteFilter() {
+      this.currentPage = 1;
+      this.loadHosts(true);
+    },
+    sortKey() {
+      this.currentPage = 1;
+      this.loadHosts(true);
+    },
+    pageSize() {
