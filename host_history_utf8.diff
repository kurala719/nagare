+    },
+    searchableColumns() {
+      return this.columnOptions.filter((col) => ['name', 'ip_addr', 'hostid', 'description', 'monitor', 'site', 'status', 'enabled'].includes(col.key));
+    },
+    selectedCount() {
+      return this.selectedHosts.length;
+    },
+  },
+  watch: {
+    '$route.query.q': function () {
+      this.applySearchFromQuery();
